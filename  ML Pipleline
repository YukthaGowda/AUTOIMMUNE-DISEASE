        "# Helper function to run cross-validation and return scores\n",
        "def run_cv(pipeline_model, X, y, cv_strategy, scoring_metrics):\n",
        "    results = cross_validate(\n",
        "        pipeline_model, X, y, cv=cv_strategy, scoring=scoring_metrics,\n",
        "        n_jobs=-1, return_train_score=False\n",
        "    )\n",
        "    return results\n",
        "\n",
        "# Helper function to summarize CV results\n",
        "def summarize_cv(method_name, scores):\n",
        "    row = {\"CV Method\": method_name}\n",
        "    for metric_name, metric_scores in scores.items():\n",
        "        # Strip 'test_' prefix if present and capitalize\n",
        "        display_name = metric_name.replace('test_', '').capitalize()\n",
        "        row[f\"{display_name} Mean\"] = float(np.mean(metric_scores))\n",
        "        row[f\"{display_name} Std\"] = float(np.std(metric_scores))\n",
        "    return row\n",
        "\n",
        "# Define the scoring dictionary based on previous metrics\n",
        "scoring = {\n",
        "    \"accuracy\": \"accuracy\",\n",
        "    \"precision_macro\": \"precision_macro\",\n",
        "    \"recall_macro\": \"recall_macro\",\n",
        "    \"f1_macro\": \"f1_macro\"\n",
        "}\n",
        "\n",
        "skf = StratifiedKFold(n_splits=10, shuffle=True, random_state=42)\n",
        "scores_10 = run_cv(pipe_clf, X_all, y, skf, scoring)\n",
        "cv10_row = summarize_cv(\"10-Fold Stratified\", scores_10)\n",
        "display(pd.DataFrame(cv10_row, index=[0]))\n",
        "\n",
        "kf = KFold(n_splits=10, shuffle=True, random_state=42)\n",
        "kf_res = cross_validate(pipe_clf, X_all, y, cv=kf, scoring=\"accuracy\", n_jobs=-1)\n",
        "kf_row = {\"CV Method\":\"KFold (10)\", \"accuracy Mean\": float(np.mean(kf_res['test_score'])),\n",
        "          \"accuracy Std\": float(np.std(kf_res['test_score']))}\n",
        "display(pd.DataFrame(kf_row, index=[0]))"
      ]
    },
