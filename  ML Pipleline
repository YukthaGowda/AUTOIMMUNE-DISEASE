      "source": [
        "# Imputation (Mean/Mode) + Shuffle"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "QLmLwVVdDc-3",
        "outputId": "4ea6a4c2-9b67-4680-fe2b-fb388c35a28c"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Imputation + shuffle done.\n"
          ]
        }
      ],
      "source": [
        "# 1) Impute: numeric → mean, categorical → mode\n",
        "df_proc = df.copy()\n",
        "for c in df_proc.columns:\n",
        "    if df_proc[c].dtype == 'O':\n",
        "        if df_proc[c].isna().any():\n",
        "            df_proc[c] = df_proc[c].fillna(df_proc[c].mode()[0])\n",
        "    else:\n",
        "        if df_proc[c].isna().any():\n",
        "            df_proc[c] = df_proc[c].fillna(df_proc[c].mean())\n",
        "\n",
        "# 2) Shuffle once to avoid order bias\n",
        "df_proc = df_proc.sample(frac=1.0, random_state=42).reset_index(drop=True)\n",
        "\n",
        "print(\"✅ Imputation + shuffle done.\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "nmeYfLnbOURs"
      },
      "source": [
        "# Feature Selection"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "R3kkoz1YDfnG",
        "outputId": "6563dbf6-12fa-4f0a-e111-65330eae2fe0"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Using SIMPLE features only:\n",
            "['Age', 'CRP', 'ESR', 'Hemoglobin', 'RBC_Count', 'Hematocrit', 'MCV', 'MCH', 'MCHC', 'Gender']\n",
            "Low-cardinality categorical kept: ['Gender']\n"
          ]
        }
      ],
      "source": [
        "\n",
        "preferred_numeric = [\n",
        "    \"Age\",\"BMI\",\"CRP\",\"ESR\",\"WBC\",\"RBC\",\"Platelets\",\"Hemoglobin\",\n",
        "    \"Glucose\",\"Cholesterol\",\"Creatinine\",\"Urea\",\"Sodium\",\"Potassium\",\n",
        "    \"ALT\",\"AST\",\"Albumin\",\"Bilirubin\",\"Calcium\",\"TSH\",\n",
        "    \"BP_Systolic\",\"BP_Diastolic\",\"HeartRate\"\n",
        "]\n",
        "preferred_categorical = [\n",
        "    \"Sex\",\"Gender\",\"Smoker\",\"FamilyHistory\",\"Diabetes\",\"Hypertension\"\n",
        "]\n",
        "\n",
        "# Target and leakage rules\n",
        "TARGET_COL = \"Diagnosis\"\n",
        "ID_LIKE    = {\"id\",\"patient_id\",\"record_id\",\"index\",\"Patient_ID\"}\n",
        "LEAKY_HINT = {\"diagnosis\",\"label\",\"class\",\"disease\",\"outcome\",\"target\"}\n",
        "\n",
        "# Drop ID-like and label-like columns from features\n",
        "to_drop = set()\n",
        "for c in df_proc.columns:\n",
        "    cl = c.lower()\n",
        "    if cl in ID_LIKE:\n",
        "        to_drop.add(c)\n",
        "    if c != TARGET_COL and any(k in cl for k in LEAKY_HINT):\n",
        "        to_drop.add(c)\n",
        "\n",
        "# Build a SIMPLE feature list from what's actually available\n",
        "present_numeric = [c for c in preferred_numeric if c in df_proc.columns]\n",
        "present_categorical = [c for c in preferred_categorical if c in df_proc.columns]\n",
        "\n",
        "# Also allow a few extra EASY numeric features if dataset names differ slightly\n",
        "# Rule: short names (<= 15 chars), numeric type, not in drop list\n",
        "extra_numeric = []\n",
        "for c in df_proc.select_dtypes(include=[np.number]).columns:\n",
        "    if c not in present_numeric and c not in to_drop and c != TARGET_COL and len(c) <= 15:\n",
        "        extra_numeric.append(c)\n",
        "# Cap extras to keep model simple\n",
        "extra_numeric = extra_numeric[:5]\n",
        "\n",
        "simple_features = present_numeric + extra_numeric + present_categorical\n",
        "# If the list somehow ends up empty, fall back to first 12 safe columns\n",
        "if not simple_features:\n",
        "    safe_cols = [c for c in df_proc.columns if c not in to_drop and c != TARGET_COL]\n",
        "    simple_features = safe_cols[:12]\n",
        "\n",
        "print(\"✅ Using SIMPLE features only:\")\n",
        "print(simple_features)\n",
        "\n",
        "X_all = df_proc[simple_features].copy()\n",
        "y_text = df_proc[TARGET_COL].copy()\n",
        "\n",
        "low_card_cats = []\n",
        "for c in present_categorical:\n",
        "    if c in X_all.columns and X_all[c].dtype == 'O':\n",
        "        if X_all[c].nunique() <= 6:\n",
        "            low_card_cats.append(c)\n",
        "        else:\n",
        "            X_all.drop(columns=[c], inplace=True)\n",
        "\n",
        "print(\"Low-cardinality categorical kept:\", low_card_cats)\n"
      ]
    },
