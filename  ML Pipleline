        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "from sklearn.preprocessing import label_binarize\n",
        "from sklearn.metrics import roc_curve, roc_auc_score\n",
        "from sklearn.model_selection import train_test_split # Added import for train_test_split\n",
        "\n",
        "# Re-split data to ensure y_test is defined in this context\n",
        "# (Assuming X_all and y are defined from previous cells)\n",
        "_, X_test, _, y_test = train_test_split(X_all, y, test_size=0.2, random_state=42, stratify=y)\n",
        "\n",
        "# Define n_classes based on the now-defined y_test\n",
        "n_classes = len(np.unique(y_test))\n",
        "\n",
        "plt.figure(figsize=(7,6))\n",
        "if n_classes == 2:\n",
        "    y_score = pipe_clf.predict_proba(X_test)[:,1]\n",
        "    fpr, tpr, _ = roc_curve(y_test, y_score)\n",
        "    auc_val = roc_auc_score(y_test, y_score)\n",
        "    plt.plot(fpr, tpr, label=f\"AUC = {auc_val:.3f}\")\n",
        "else:\n",
        "    Yb = label_binarize(y_test, classes=np.arange(n_classes))\n",
        "    y_prob = pipe_clf.predict_proba(X_test)\n",
        "    aucs = [roc_auc_score(Yb[:,i], y_prob[:,i]) for i in range(n_classes)]\n",
        "    macro_auc = np.mean(aucs)\n",
        "    plt.plot([0,1],[0,1],'k--')\n",
        "    plt.text(0.60, 0.20, f\"Macro AUC = {macro_auc:.3f}\", fontsize=12)\n",
        "\n",
        "plt.xlabel(\"False Positive Rate\"); plt.ylabel(\"True Positive Rate\")\n",
        "plt.title(\"ROC — XGBoost (simple features)\")\n",
        "plt.legend(loc=\"lower right\"); plt.show()"
