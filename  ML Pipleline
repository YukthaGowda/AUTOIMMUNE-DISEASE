      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Classes: ['Autoimmune orchitis', \"Graves' disease\", 'Other', 'Rheumatoid arthritis', 'Sjögren syndrome', 'Systemic lupus erythematosus (SLE)']\n",
            "Numeric cols: ['Age', 'CRP', 'ESR', 'Hemoglobin', 'RBC_Count', 'Hematocrit', 'MCV', 'MCH', 'MCHC']\n",
            "Categorical cols: ['Gender']\n"
          ]
        }
      ],
      "source": [
        "# Encode y\n",
        "le = LabelEncoder()\n",
        "y = le.fit_transform(y_text)\n",
        "class_names = le.classes_.tolist()\n",
        "n_classes = len(class_names)\n",
        "print(\"Classes:\", class_names)\n",
        "\n",
        "# Define numeric & categorical columns from the SIMPLE set\n",
        "num_cols = X_all.select_dtypes(include=[np.number]).columns.tolist()\n",
        "cat_cols = [c for c in low_card_cats if c in X_all.columns]\n",
        "\n",
        "# Preprocessor\n",
        "try:\n",
        "    ohe = OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False)\n",
        "except TypeError:\n",
        "    ohe = OneHotEncoder(handle_unknown=\"ignore\", sparse=False)\n",
        "\n",
        "ct = ColumnTransformer([\n",
        "    (\"num\", StandardScaler(), num_cols),\n",
        "    (\"cat\", ohe, cat_cols),\n",
        "], remainder=\"drop\")\n",
        "\n",
        "print(\"Numeric cols:\", num_cols)\n",
        "print(\"Categorical cols:\", cat_cols)\n"
      ]
    },
