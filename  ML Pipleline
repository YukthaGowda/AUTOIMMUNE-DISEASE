        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "import shap\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.inspection import permutation_importance # Import here for backup\n",
        "\n",
        "\n",
        "# Helper function to get feature names from ColumnTransformer\n",
        "# (Assuming num_cols and cat_cols are globally defined from cell 6TiZSLVZDjPr)\n",
        "def feature_names_from_ct(ct, cat_cols, num_cols):\n",
        "    names = []\n",
        "    for name, trans, cols_in_transformer in ct.transformers_:\n",
        "        if name == \"num\":\n",
        "            # For numeric, use the original num_cols which were passed to the transformer\n",
        "            names.extend(list(num_cols))\n",
        "        elif name == \"cat\":\n",
        "            ohe = trans\n",
        "            try:\n",
        "                # For categorical, get names from OHE, using the original cat_cols\n",
        "                names.extend(ohe.get_feature_names_out(cat_cols))\n",
        "            except AttributeError: # Fallback for older sklearn versions\n",
        "                names.extend([f\"{c}_encoded\" for c in cols_in_transformer])\n",
        "    return names\n",
        "\n",
        "# Ensure best_model, X_test, y_test, num_cols, cat_cols are defined from previous cells.\n",
        "# If they are not, this block will raise a NameError and that is expected.\n",
        "\n",
        "# Extract preprocessor and model from the best_model pipeline\n",
        "prep = best_model.named_steps[\"prep\"]\n",
        "mdl  = best_model.named_steps[\"model\"]\n",
        "\n",
        "# Get feature names from the ColumnTransformer\n",
        "# Assumes 'num_cols' and 'cat_cols' are defined globally from cell 6TiZSLVZDjPr\n",
        "feat_names = feature_names_from_ct(prep, cat_cols, num_cols)\n",
        "\n",
        "# Transform X_test for SHAP and permutation importance\n",
        "X_test_trans = prep.transform(X_test)\n",
        "Xtt = pd.DataFrame(X_test_trans, columns=feat_names)\n",
        "\n",
        "\n",
        "# 1) Preferred: model-agnostic wrapper (handles sklearn XGB + multiclass cleanly)\n",
        "try:\n",
        "    print(\"Attempting SHAP with shap.Explainer (model-agnostic wrapper)...\")\n",
        "    explainer = shap.Explainer(mdl, Xtt)   # SHAP picks correct backend\n",
        "    sv = explainer(Xtt)                    # Explanation object\n",
        "    shap.plots.beeswarm(sv, max_display=20)   # global summary plot\n",
        "    plt.title(\"SHAP Beeswarm Plot (Global Feature Importance)\")\n",
        "    plt.show()\n",
        "\n",
        "except Exception as e:\n",
        "    print(f\"Primary SHAP path failed: {e}. Falling back to TreeExplainer or Permutation Importance.\")\n",
        "\n",
        "    # 2) Fallback: use Booster directly + fix base_score for multiclass bug\n",
        "    try:\n",
        "        print(\"Attempting SHAP with shap.TreeExplainer (XGBoost specific)...\")\n",
        "        booster = mdl.get_booster()\n",
        "\n",
        "        # fix SHAP multiclass scalar base_score issue\n",
        "        # This is a common workaround for older SHAP versions with XGBoost multiclass\n",
        "        try:\n",
        "            base_score = booster.attr(\"base_score\")\n",
        "            if isinstance(base_score, str) and base_score.startswith(\"[\"):\n",
        "                booster.set_attr(base_score=\"0.5\")\n",
        "        except Exception:\n",
        "            pass # Ignore if base_score attribute is not found or cannot be modified\n",
        "\n",
        "        explainer = shap.TreeExplainer(booster)\n",
        "        shap_vals = explainer.shap_values(Xtt.values)\n",
        "\n",
        "        # For multiclass, shap_vals is a list of arrays, one for each class\n",
